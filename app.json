{
  "expo": {
    "name": "Clean_Up",
    "slug": "Clean_Up",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cleanup",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.robertdunn.cleanup",
      "adaptiveIcon": {
        "backgroundColor": "#E8F5E9",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Clean Up to use your location to show cleanup events near you."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#5CB85C",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Clean Up to access your photos to set a profile picture.",
          "cameraPermission": "Allow Clean Up to use the camera to take a profile photo."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#5CB85C"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c3e10c3d-d271-4dc3-98dc-c5f378ec5b2e"
      }
    },
    "owner": "robdunn220"
  }
}
